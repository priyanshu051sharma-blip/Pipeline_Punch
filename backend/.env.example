# Server Configuration
PORT=3000
NODE_ENV=production

# MongoDB Connection (use MongoDB Atlas for production)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aquasync
# Local development: mongodb://127.0.0.1:27017/water_dashboard

# CORS Configuration (comma-separated origins for local + production)
CORS_ORIGINS=http://localhost:5173,https://your-vercel-domain.vercel.app

# ThingSpeak Integration (optional)
THINGSPEAK_ENABLED=false
THINGSPEAK_CHANNEL_ID=
THINGSPEAK_READ_API_KEY=
THINGSPEAK_POLL_SECONDS=15

# Hardware Integration (optional)
HARDWARE_ENABLED=false
