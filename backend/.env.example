PORT=3000
NODE_ENV=development
HARDWARE_ENABLED=false

# Local MongoDB (Compass / mongod on your machine)
MONGODB_URI=mongodb://127.0.0.1:27017/water_dashboard

# Atlas example (replace placeholders)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/water_dashboard?retryWrites=true&w=majority&appName=water-dashboard

# ThingSpeak real-time integration
THINGSPEAK_ENABLED=false
THINGSPEAK_CHANNEL_ID=
THINGSPEAK_READ_API_KEY=
THINGSPEAK_POLL_SECONDS=15
