# AquaSync Frontend Environment Configuration
# Copy this file to .env.local for local development
# For production, set these in Vercel project settings

# API Configuration
# Local development:
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000

# Production (set these in Vercel):
# VITE_API_URL=https://aquasync-backend.onrender.com/api
# VITE_WS_URL=wss://aquasync-backend.onrender.com
